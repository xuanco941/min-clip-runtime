{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/main",
    "rootDir": "src",
    "types": ["node"],
    "lib": ["ES2022"],
    "sourceMap": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts"
  ]
}